DISCORD_BOT_TOKEN=replace_with_discord_bot_token

# LLM PROVIDER PRIORITY
# The runtime reads API key lines from TOP to BOTTOM in this file.
# The first non-empty API key is tried first. If that provider fails, the next
# non-empty API key below it is tried as a fallback.
#
# To make Gemini first, move the GEMINI_API_KEY line above OPENAI_API_KEY.
# You may reorder the provider blocks below. Blank API keys are ignored.
# When keys are injected by Docker/the host instead of this file, fallback order is:
# OpenAI -> Gemini -> Claude -> OpenRouter -> AgentRouter.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini (Google OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Claude / Anthropic (native Messages API)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AgentRouter (OpenAI-compatible)
AGENTROUTER_API_KEY=
AGENTROUTER_MODEL=gpt-5.5
AGENTROUTER_BASE_URL=https://agentrouter.org/v1

SKILLS_DIR=./skills
TERMINAL_MODE=off
TERMINAL_CWD=./workspace
